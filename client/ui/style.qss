/* ============================================================
   LLME — Dark theme
   Palette:
     bg          #0d0d0f   app background
     surface     #1a1a1d   cards, panels, side rails
     surface-2   #232327   inputs, dropdowns, hover surfaces
     border      #2c2c31   subtle dividers
     text        #e6e6e9   primary text
     text-muted  #8b8b93   secondary text, placeholders
     accent      #3b82f6   primary buttons, focus rings, active nav
     accent-hov  #2563eb
     danger      #ef4444   destructive actions
     danger-hov  #dc2626
   ============================================================ */

/* ---------- Base ---------- */
QMainWindow,
QWidget#centralwidget,
QStackedWidget,
QStackedWidget > QWidget {
    background-color: #0d0d0f;
    color: #e6e6e9;
    font-family: "Inter", "Segoe UI", "SF Pro Text", sans-serif;
    font-size: 13px;
}

QLabel {
    background-color: transparent;
    color: #e6e6e9;
    font-family: "Inter", "Segoe UI", "SF Pro Text", sans-serif;
    font-size: 13px;
}

QTabWidget > QWidget {
    background-color: transparent;
}

QToolTip {
    background-color: #1a1a1d;
    color: #e6e6e9;
    border: 1px solid #2c2c31;
    padding: 6px 8px;
    border-radius: 6px;
}

/* ---------- Login screen ---------- */
QFrame#loginCard {
    background-color: #1a1a1d;
    border: 1px solid #2c2c31;
    border-radius: 16px;
}

QLabel#lblBrand {
    font-size: 32px;
    font-weight: 800;
    letter-spacing: 4px;
    color: #e6e6e9;
}

QLabel#lblTagline {
    color: #8b8b93;
    font-size: 13px;
}

/* ---------- Main window sidebar ---------- */
QFrame#sidebar {
    background-color: #131316;
    border-right: 1px solid #2c2c31;
}

QLabel#sidebarLogo {
    background-color: #3b82f6;
    color: white;
    font-weight: 800;
    font-size: 18px;
    border-radius: 10px;
}

QFrame#sidebar QPushButton {
    background-color: transparent;
    color: #8b8b93;
    border: none;
    border-radius: 10px;
    font-size: 18px;
    padding: 0;
}
QFrame#sidebar QPushButton:hover {
    background-color: #232327;
    color: #e6e6e9;
}
QFrame#sidebar QPushButton:checked {
    background-color: #232327;
    color: #3b82f6;
}

/* ---------- Sessions slide-out panel ---------- */
QFrame#sessionsPanel {
    background-color: #131316;
    border-right: 1px solid #2c2c31;
}

QLabel#lblSessionsHeader {
    font-size: 18px;
    font-weight: 700;
    color: #e6e6e9;
}

QPushButton[sessionRow="true"] {
    background-color: transparent;
    color: #e6e6e9;
    border: 1px solid transparent;
    border-radius: 8px;
    padding: 10px 12px;
    text-align: left;
    font-size: 13px;
}
QPushButton[sessionRow="true"]:hover {
    background-color: #1a1a1d;
    border-color: #2c2c31;
}
QPushButton[sessionRow="true"]:checked,
QPushButton[sessionRow="true"][active="true"] {
    background-color: #1a1a1d;
    border-color: #3b82f6;
    color: #ffffff;
}

/* ---------- Welcome screen ---------- */
QLabel#lblWelcomeLogo {
    background-color: #3b82f6;
    color: white;
    font-size: 44px;
    font-weight: 800;
    border-radius: 22px;
    qproperty-alignment: AlignCenter;
}

QWidget#welcomeColumn QLabel#lbl_welcomegreeting {
    font-size: 36px;
    font-weight: 700;
    color: #e6e6e9;
}

QWidget#welcomeColumn QLabel#lblWelcomeSubtitle {
    font-size: 18px;
    color: #8b8b93;
}

QFrame#welcomeInputBar {
    background-color: #1a1a1d;
    border: 1px solid #2c2c31;
    border-radius: 14px;
}

QFrame#welcomeInputBar QLineEdit {
    background-color: transparent;
    border: none;
    font-size: 15px;
    padding: 4px 8px;
}

QFrame#welcomeInputBar QPushButton#btn_attachwelcome {
    background-color: transparent;
    color: #8b8b93;
    border: none;
    border-radius: 10px;
    font-size: 18px;
}
QFrame#welcomeInputBar QPushButton#btn_attachwelcome:hover {
    background-color: #232327;
    color: #e6e6e9;
}

/* suggestion cards */
QPushButton[suggestionCard="true"] {
    background-color: #1a1a1d;
    color: #e6e6e9;
    border: 1px solid #2c2c31;
    border-radius: 14px;
    text-align: left;
    padding: 16px 18px;
    font-size: 14px;
}
QPushButton[suggestionCard="true"]:hover {
    background-color: #232327;
    border-color: #3b82f6;
}
QPushButton[suggestionCard="true"]:pressed {
    background-color: #1f1f23;
}

/* card flash — applied transiently after click */
QPushButton[suggestionFlash="true"] {
    background-color: rgba(59, 130, 246, 0.20);
    border: 2px solid #3b82f6;
    color: #ffffff;
}

/* ---------- Generic cards (settings + input bar) ---------- */
QFrame#inputBar,
QFrame#generalAppearanceCard,
QFrame#generalDefaultsCard,
QFrame#generalAccountCard,
QFrame#modelEngineCard,
QFrame#modelSamplingCard,
QFrame#modelPromptCard,
QFrame#modelGeminiCard,
QFrame#ragToggleCard,
QFrame#ragQuotaCard,
QFrame#ragDocsCard,
QFrame#aboutCard {
    background-color: #1a1a1d;
    border: 1px solid #2c2c31;
    border-radius: 12px;
}

QLabel[cardTitle="true"] {
    font-size: 14px;
    font-weight: 600;
    color: #e6e6e9;
}
QLabel[helpText="true"] {
    color: #8b8b93;
    font-size: 12px;
}

QLabel#lblSettingsTitle {
    font-size: 22px;
    font-weight: 700;
    color: #e6e6e9;
}
QLabel#lbl_messagessessiontitle {
    font-size: 18px;
    font-weight: 600;
    color: #e6e6e9;
    padding-left: 4px;
}

QLabel#lblAboutTitle {
    font-size: 32px;
    font-weight: 800;
    letter-spacing: 3px;
    color: #e6e6e9;
}

/* ---------- Buttons ---------- */
QPushButton {
    background-color: #232327;
    color: #e6e6e9;
    border: 1px solid #2c2c31;
    border-radius: 8px;
    padding: 6px 14px;
}
QPushButton:hover {
    background-color: #2a2a2f;
    border-color: #3b3b42;
}
QPushButton:pressed {
    background-color: #1f1f23;
}
QPushButton:disabled {
    color: #5a5a62;
    background-color: #18181b;
}

QPushButton[primary="true"] {
    background-color: #3b82f6;
    color: white;
    border: 1px solid #3b82f6;
    font-weight: 600;
}
QPushButton[primary="true"]:hover {
    background-color: #2563eb;
    border-color: #2563eb;
}
QPushButton[primary="true"]:pressed {
    background-color: #1d4ed8;
}

QPushButton[danger="true"] {
    background-color: transparent;
    color: #ef4444;
    border: 1px solid #ef4444;
}
QPushButton[danger="true"]:hover {
    background-color: rgba(239, 68, 68, 0.12);
    color: #fca5a5;
    border-color: #fca5a5;
}

/* ---------- Inputs ---------- */
QLineEdit, QPlainTextEdit, QTextEdit {
    background-color: #232327;
    color: #e6e6e9;
    border: 1px solid #2c2c31;
    border-radius: 8px;
    padding: 6px 10px;
    selection-background-color: #3b82f6;
    selection-color: white;
}
QLineEdit:focus, QPlainTextEdit:focus, QTextEdit:focus {
    border: 1px solid #3b82f6;
}

QSpinBox, QDoubleSpinBox {
    background-color: #232327;
    color: #e6e6e9;
    border: 1px solid #2c2c31;
    border-radius: 8px;
    padding: 4px 8px;
}
QSpinBox:focus, QDoubleSpinBox:focus {
    border: 1px solid #3b82f6;
}
QSpinBox::up-button, QSpinBox::down-button,
QDoubleSpinBox::up-button, QDoubleSpinBox::down-button {
    background-color: transparent;
    border: none;
    width: 16px;
}

/* ---------- ComboBox ---------- */
QComboBox {
    background-color: #232327;
    color: #e6e6e9;
    border: 1px solid #2c2c31;
    border-radius: 8px;
    padding: 4px 10px;
}
QComboBox:hover {
    border-color: #3b3b42;
}
QComboBox:focus {
    border-color: #3b82f6;
}
QComboBox::drop-down {
    border: none;
    width: 24px;
}
QComboBox::down-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid #8b8b93;
    margin-right: 8px;
}
QComboBox QAbstractItemView {
    background-color: #1a1a1d;
    color: #e6e6e9;
    border: 1px solid #2c2c31;
    border-radius: 8px;
    selection-background-color: #232327;
    selection-color: #3b82f6;
    outline: 0;
    padding: 4px;
}

/* ---------- Tabs ---------- */
QTabWidget::pane {
    border: 1px solid #2c2c31;
    border-radius: 12px;
    background-color: #131316;
    top: -1px;
}
QTabBar::tab {
    background-color: transparent;
    color: #8b8b93;
    padding: 8px 18px;
    margin-right: 4px;
    border: 1px solid transparent;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    font-weight: 500;
}
QTabBar::tab:hover {
    color: #e6e6e9;
}
QTabBar::tab:selected {
    background-color: #1a1a1d;
    color: #3b82f6;
    border: 1px solid #2c2c31;
    border-bottom-color: #1a1a1d;
}

/* ---------- Menus (for sessions popup) ---------- */
QMenu {
    background-color: #1a1a1d;
    color: #e6e6e9;
    border: 1px solid #2c2c31;
    border-radius: 8px;
    padding: 6px;
}
QMenu::item {
    padding: 8px 16px;
    border-radius: 6px;
}
QMenu::item:selected {
    background-color: #232327;
    color: #3b82f6;
}
QMenu::separator {
    height: 1px;
    background-color: #2c2c31;
    margin: 4px 8px;
}

/* ---------- Scroll areas ---------- */
QScrollArea {
    background-color: transparent;
    border: none;
}
QScrollArea > QWidget > QWidget {
    background-color: transparent;
}
QScrollBar:vertical {
    background: transparent;
    width: 10px;
    margin: 4px 2px 4px 0;
}
QScrollBar::handle:vertical {
    background: #2c2c31;
    border-radius: 4px;
    min-height: 24px;
}
QScrollBar::handle:vertical:hover {
    background: #3b3b42;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}
QScrollBar:horizontal {
    background: transparent;
    height: 10px;
    margin: 0 4px 2px 4px;
}
QScrollBar::handle:horizontal {
    background: #2c2c31;
    border-radius: 4px;
    min-width: 24px;
}
QScrollBar::handle:horizontal:hover {
    background: #3b3b42;
}
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0;
}

/* ---------- ProgressBar (RAG quota) ---------- */
QProgressBar {
    background-color: #232327;
    border: 1px solid #2c2c31;
    border-radius: 6px;
    text-align: center;
    color: #e6e6e9;
}
QProgressBar::chunk {
    background-color: #3b82f6;
    border-radius: 5px;
}

/* ---------- CheckBox ---------- */
QCheckBox {
    spacing: 8px;
}
QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border-radius: 5px;
    border: 1px solid #2c2c31;
    background-color: #232327;
}
QCheckBox::indicator:hover {
    border-color: #3b3b42;
}
QCheckBox::indicator:checked {
    background-color: #3b82f6;
    border-color: #3b82f6;
}

/* ---------- Chat bubbles ---------- */
QLabel[bubbleRole="user"] {
    background-color: #3b82f6;
    color: white;
    border-radius: 14px;
    padding: 10px 14px;
}
QLabel[bubbleRole="assistant"] {
    background-color: #1a1a1d;
    color: #e6e6e9;
    border: 1px solid #2c2c31;
    border-radius: 14px;
    padding: 10px 14px;
}

/* ---------- RAG document row ---------- */
QFrame[ragDocRow="true"] {
    background-color: #232327;
    border: 1px solid #2c2c31;
    border-radius: 8px;
    padding: 4px 8px;
}

QFrame#sessionBar QLabel,
QFrame#inputBar QLabel,
QFrame#welcomeInputBar QLabel {
    background-color: transparent;
    border: none;
}

QPushButton[sessionDelete="true"] {
    background-color: transparent;
    color: #8b8b93;
    border: none;
    border-radius: 6px;
    font-size: 16px;
    font-weight: 700;
    padding: 0;
}
QPushButton[sessionDelete="true"]:hover {
    background-color: rgba(239, 68, 68, 0.18);
    color: #ef4444;
}
